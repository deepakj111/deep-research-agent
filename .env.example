# === LLM API Keys ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# === Search & Data APIs ===
TAVILY_API_KEY=tvly-...
GITHUB_TOKEN=ghp_...

# === MCP Auth ===
MCP_JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# === MCP Server URLs ===
WEB_SEARCH_MCP_URL=http://localhost:8001/sse
ARXIV_MCP_URL=http://localhost:8002/sse
